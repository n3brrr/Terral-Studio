---
import "../styles/global.css";
---

<section class="relative">
  <img
    src="/photos/hero-photo.webp"
    alt="Imagen de la casa"
    class="w-full h-screen object-cover"
  />
  <div
    class="absolute inset-0 bg-linear-to-t from-background/80 via-transparent to-transparent flex flex-col items-start justify-center shadow-xl"
  >
    <h1
      class="text-5xl sm:text-6xl md:text-8xl font-bold text-white tracking-tighter px-6 md:px-12"
    >
      Terral Studio
    </h1>
    <div
      class="absolute bottom-8 md:bottom-10 w-full px-6 md:px-12 flex flex-col sm:flex-row justify-between items-start sm:items-end gap-2 sm:gap-0 uppercase"
    >
      <h2 class="text-sm sm:text-md font-bold text-white/80 md:text-xl tracking-tighter">
        un nuevo estandar de diseño
      </h2>
      <h3 class="text-sm sm:text-md font-bold text-white/80 md:text-xl tracking-tighter">
        málaga, españa
      </h3>
    </div>
  </div>
</section>
