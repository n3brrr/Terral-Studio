---

---

<nav
  class="absolute top-8 left-0 w-full px-6 md:px-12 z-10 flex justify-between items-center"
>
  <div class="flex items-center gap-2 text-white/70">
    <span class="text-2xl font-bold uppercase tracking-tighter"
      >Terral Studio</span
    >
  </div>

  <!-- Links desktop -->
  <div
    class="hidden md:flex items-center gap-4 text-white/70 uppercase tracking-wider font-light"
  >
    <a href="#services" class="text-sm font-bold">Servicios</a>
    <a href="#houseplan" class="text-sm font-bold">Planos</a>
    <a href="#proyects" class="text-sm font-bold">Proyectos</a>
    <a href="#reviews" class="text-sm font-bold">Reseñas</a>
    <a href="#footer" class="text-sm font-bold">Contacto</a>
  </div>

  <!-- Botón hamburguesa  -->
  <button
    id="menu-toggle"
    aria-label="Abrir menú"
    class="md:hidden flex flex-col gap-1.5 p-2 text-white/80 focus:outline-none"
  >
    <span
      class="block w-6 h-0.5 bg-white/80 transition-all duration-300"
      id="bar1"></span>
    <span
      class="block w-6 h-0.5 bg-white/80 transition-all duration-300"
      id="bar2"></span>
    <span
      class="block w-6 h-0.5 bg-white/80 transition-all duration-300"
      id="bar3"></span>
  </button>
</nav>

<!-- Menú mobile desplegable -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 bg-black/95 backdrop-blur-md flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-500 md:hidden"
>
  <button
    id="menu-close"
    aria-label="Cerrar menú"
    class="absolute top-8 right-6 text-white/70 text-3xl font-light leading-none"
  >
    ✕
  </button>
  <a
    href="#services"
    class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white/80 hover:text-accent transition-colors"
    >Servicios</a
  >
  <a
    href="#houseplan"
    class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white/80 hover:text-accent transition-colors"
    >Planos</a
  >
  <a
    href="#proyects"
    class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white/80 hover:text-accent transition-colors"
    >Proyectos</a
  >
  <a
    href="#reviews"
    class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white/80 hover:text-accent transition-colors"
    >Reseñas</a
  >
  <a
    href="#footer"
    class="mobile-link text-4xl font-bold uppercase tracking-tighter text-white/80 hover:text-accent transition-colors"
    >Contacto</a
  >
</div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const closeBtn = document.getElementById("menu-close");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  function openMenu() {
    mobileMenu?.classList.remove("translate-x-full");
    mobileMenu?.classList.add("translate-x-0");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    mobileMenu?.classList.remove("translate-x-0");
    mobileMenu?.classList.add("translate-x-full");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", openMenu);
  closeBtn?.addEventListener("click", closeMenu);
  mobileLinks.forEach((link) => link.addEventListener("click", closeMenu));
</script>
